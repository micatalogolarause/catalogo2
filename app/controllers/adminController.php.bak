            $descripcion = sanitizar($_POST['descripcion'] ?? '');
            
            if (!$nombre || !$categoria_id) {
                $_SESSION['error'] = 'El nombre de la subcategoría y la categoría son requeridos';
            } else {
                $resultado = $this->subcategoriaModel->actualizar($id, $nombre, $descripcion);
